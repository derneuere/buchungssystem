# ---- Frontend (Build-/Dev-Zeit, Vite) ----
# Nur in der lokalen Entwicklung nötig, wenn Vite (:3000) und PocketBase (:8090)
# getrennt laufen. In Produktion NICHT setzen -> Client nutzt same-origin.
VITE_PB_URL=http://127.0.0.1:8090

# ---- Backend (Laufzeit, PocketBase-Binary) ----
# Kommagetrennte erlaubte Einbettungs-Domains für die CSP frame-ancestors.
# 'self' ist immer erlaubt. Hier die TYPO3-Produktions-/Staging-Domain(s):
EMBED_FRAME_ANCESTORS=https://www.gdw-berlin.de https://gdw-berlin.de

# Optionaler initialer Mitarbeiter-Account (nur beim ersten Seed angelegt).
# Ohne diese Werte wird KEIN Account erstellt (Superuser via CLI anlegen).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# SMTP für Transaktionsmails wird im PocketBase-Admin (/_/ -> Settings -> Mail)
# konfiguriert, nicht per Env.
